# ========== 模型缓存路径 ==========
# 指向 download_models.py 下载的模型目录，设置为空则使用 HuggingFace 默认缓存
MODEL_CACHE_DIR=/mnt/workspace/user8/AI-customer-service/backend/models

# ========== LLM 配置 (vLLM 本地部署) ==========
VLLM_BASE_URL=http://localhost:8081/v1
VLLM_API_KEY=EMPTY
LLM_MODEL_NAME=Qwen3.5-9B
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ========== Embedding 配置 (BGE) ==========
EMBEDDING_MODEL_NAME=/mnt/workspace/user8/AI-customer-service/models/BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cuda:1

# ========== Reranker 配置 ==========
RERANKER_MODEL_NAME=/mnt/workspace/user8/AI-customer-service/models/BAAI/bge-reranker-large
RERANKER_DEVICE=cuda:1

# ========== Milvus 向量库配置 ==========
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=customer_service_kb

# ========== PostgreSQL 配置 ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=customer_service

# ========== Redis 配置 ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ========== 服务配置 ==========
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ========== 知识库配置 ==========
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5
RERANK_TOP_K=3